REACT_APP_API_URL=http://localhost:5000/api

# OpenRouter AI (for Fact-Checker)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DETECTOR=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_SKEPTIC=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_VISION=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Sentinel SG

# Fact-Checker Settings
FACTCHECK_MODE=live
FACTCHECK_MAX_FILE_SIZE_MB=10
FACTCHECK_TIMEOUT_MS=30000
FACTCHECK_MIN_PROCESSING_TIME_MS=3000
